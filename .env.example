# =============================================================================
# eSTOCK Backend — Example environment file
# =============================================================================
# Copy this file to .env (or app.env) and fill in your values.
# Never commit .env or app.env to version control.
# See: eSTOCK doc/Roadmap - Env Backend.md
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# Option A: separate vars (PostgreSQL or SQL Server)
# For local dev: set ENVIRONMENT=development and use DB_USER=postgres (no need to create estock_user).
# Then: createdb estock_db  (or use DB_NAME=postgres)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=estock_db
# Option B: single URL (overrides Option A if set). Use for app and make migrate-*.
# Prefer 127.0.0.1 instead of localhost to avoid IPv6 resolution issues.
# DB_SOURCE=postgresql://estock_user:your_db_password@127.0.0.1:5432/estock_db?sslmode=disable
# DATABASE_URL=postgresql://estock_user:your_db_password@127.0.0.1:5432/estock_db?sslmode=disable
# Migrations: path to SQL files (default: file://db/migrations). Used at startup and by migrate CLI.
MIGRATION_URL=file://db/migrations

# =============================================================================
# SECURITY (JWT / tokens and encryption)
# =============================================================================
# Used for JWT signing and validation. Use a long, random secret (min 32 chars).
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars_recommended
# Deprecated (fallback only): Secret=... — prefer JWT_SECRET

# =============================================================================
# APPLICATION
# =============================================================================
# Gin mode and logging: release (default), debug, development, test
# - debug | development: Gin debug mode + zerolog console (human-readable) to stderr
# - release | other: Gin release mode + zerolog JSON to stderr
# Use development for local so DB defaults to postgres@127.0.0.1 if DB_* are unset
ENVIRONMENT=development
# Bind address for the HTTP server (default: :8080 if unset)
SERVER_ADDRESS=:8080
# Application version (optional; may be used in responses or headers)
Version=2.0.0

# =============================================================================
# DEFAULT ADMIN SEEDING
# =============================================================================
# At startup, eSTOCK ensures at least one Admin user exists.
# If no Admin is found, one is created with these credentials.
#
# In ENVIRONMENT=development, falls back to dev@local.test / 12345678 when unset.
# In production (ePlatform flow), leave unset — ePlatform provisions the admin.
#
# DEFAULT_ADMIN_EMAIL=admin@mycompany.com
# DEFAULT_ADMIN_PASSWORD=change-me-on-first-login

# =============================================================================
# EMAIL + PUBLIC URL (S2 — notifications + password reset)
# =============================================================================
# Public URL of the frontend — used to build password reset links in emails
APP_URL=http://localhost:4200
# Resend API key for transactional emails (optional; if unset, emails are logged to stdout)
# RESEND_API_KEY=re_your_key_here
# Resend from address (optional; defaults to noreply@estock.app)
# RESEND_FROM_ADDRESS=noreply@yourdomain.com

# =============================================================================
# MULTI-TENANT (S2 — single-tenant default)
# =============================================================================
# UUID of the current tenant. Single-tenant mode: defaults to fixed UUID if unset.
# TENANT_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# SELF-SERVICE SIGNUP (S3-W5-A)
# =============================================================================
# Gates the public /api/signup endpoint.
# Default: true in ENVIRONMENT=development, false in all other environments.
# Keep false in prod until S3.5 (articles tenant_id isolation is complete).
# Each new tenant triggers SeedFarma in the background (5-min timeout).
ENABLE_SIGNUP=false

# =============================================================================
# STRIPE BILLING (S3-W5-B)
# =============================================================================
# Stripe secret API key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook endpoint signing secret (whsec_...) — obtain from Stripe Dashboard or CLI
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs for each plan (obtain from Stripe Dashboard > Products > Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
