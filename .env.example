# =============================================================================
# eSTOCK Backend — Example environment file
# =============================================================================
# Copy this file to .env (or app.env) and fill in your values.
# Never commit .env or app.env to version control.
# See: eSTOCK doc/Roadmap - Env Backend.md
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# Option A: separate vars (PostgreSQL or SQL Server)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=estock_user
DB_PASSWORD=your_db_password
DB_NAME=estock_db
# Option B: single URL (overrides Option A if set). Use for app and make migrate-*.
# Prefer 127.0.0.1 instead of localhost to avoid IPv6 resolution issues.
# DB_SOURCE=postgresql://estock_user:your_db_password@127.0.0.1:5432/estock_db?sslmode=disable
# DATABASE_URL=postgresql://estock_user:your_db_password@127.0.0.1:5432/estock_db?sslmode=disable
# Migrations: path to SQL files (default: file://db/migrations). Used at startup and by migrate CLI.
MIGRATION_URL=file://db/migrations

# =============================================================================
# SECURITY (JWT / tokens and encryption)
# =============================================================================
# Used for JWT signing and validation. Use a long, random secret (min 32 chars).
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars_recommended
# Deprecated (fallback only): Secret=... — prefer JWT_SECRET

# =============================================================================
# APPLICATION
# =============================================================================
# Gin mode: release (default), debug, development, test
ENVIRONMENT=release
# Bind address for the HTTP server (default: :8080 if unset)
SERVER_ADDRESS=:8080
# Application version (optional; may be used in responses or headers)
Version=1.0.0
